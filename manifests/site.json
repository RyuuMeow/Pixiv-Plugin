{
  "site_id": "pixiv",
  "display_name": "Pixiv",
  "domains": ["pixiv.net", "www.pixiv.net"],
  "browser_auth": {
    "login_url": "https://accounts.pixiv.net/login?return_to=https%3A%2F%2Fwww.pixiv.net%2Fen%2F&lang=en&source=pc&view_type=page",
    "cookie_domains": ["pixiv.net"],
    "required_cookies": ["PHPSESSID"]
  },
  "url_rules": [
    {
      "name": "artwork",
      "pattern": "^https://(?:www\\.)?pixiv\\.net/artworks/(?P<artwork_id>[0-9]+)/?$",
      "input_kind": "single",
      "operation": "artwork"
    },
    {
      "name": "user_illustrations",
      "pattern": "^https://(?:www\\.)?pixiv\\.net/users/(?P<user_id>[0-9]+)(?:/(?:illustrations|manga))?/?$",
      "input_kind": "batch",
      "operation": "user_illustrations"
    }
  ],
  "operations": {
    "artwork": {
      "requires_live_network_confirmation": true,
      "params": {}
    },
    "user_illustrations": {
      "requires_live_network_confirmation": true,
      "params": {
        "page": {
          "type": "integer",
          "default": 1,
          "min": 1,
          "editable": true,
          "visible": false
        },
        "page_size": {
          "type": "integer",
          "default": 20,
          "min": 1,
          "max": 100
        }
      }
    }
  },
  "output": {
    "fields": ["author_name", "artwork_id"],
    "default_folder_template": "{author_name}/{artwork_id}-{title}"
  },
  "network": {
    "max_concurrency": 2,
    "min_interval_seconds": 0.75,
    "retryable_status_codes": [429],
    "max_attempts": 5,
    "max_backoff_seconds": 300.0
  },
  "settings": {
    "language": {
      "type": "string",
      "default": "en",
      "enum": ["en", "ja", "zh"]
    },
    "http.user_agent": {
      "type": "string",
      "default": "Mozilla/5.0 CLI-Downloader/0.1"
    },
    "http.timeout_seconds": {
      "type": "number",
      "default": 30.0,
      "min": 1.0,
      "max": 120.0
    }
  },
  "secrets": {}
}
